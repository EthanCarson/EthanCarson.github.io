<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Shadow Dojo: Kinetic Master</title>
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- MediaPipe Pose Libraries -->
    <script src="https://cdn.jsdelivr.net/npm/@mediapipe/pose/pose.js" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/@mediapipe/camera_utils/camera_utils.js" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/@mediapipe/drawing_utils/drawing_utils.js" crossorigin="anonymous"></script>
    
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Permanent+Marker&family=Rajdhani:wght@500;700&display=swap');

        :root {
            --dojo-red: #ff4d4d;
            --dojo-gold: #ffd700;
            --dojo-blue: #00d4ff;
        }

        body {
            background-color: #0a0a0c;
            color: #ffffff;
            font-family: 'Rajdhani', sans-serif;
            overflow: hidden;
            margin: 0;
            padding: 0;
        }

        .title-font {
            font-family: 'Permanent Marker', cursive;
        }

        #game-container {
            position: relative;
            width: 100vw;
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        #input-video {
            display: none;
        }

        #output-canvas {
            width: 100%;
            height: 100%;
            object-fit: cover;
            filter: brightness(0.6) contrast(1.2);
        }

        .ui-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            display: flex;
            flex-direction: column;
            padding: 2rem;
        }

        .interactive {
            pointer-events: auto;
        }

        .status-bar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            width: 100%;
        }

        .health-bar-container {
            width: 300px;
            height: 20px;
            background: #222;
            border-radius: 10px;
            overflow: hidden;
            border: 2px solid #444;
        }

        #health-fill {
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, var(--dojo-red), #ff9999);
            transition: width 0.3s ease;
        }

        .flash-red {
            animation: flash 0.5s infinite;
        }

        @keyframes flash {
            0% { background-color: rgba(255, 77, 77, 0); }
            50% { background-color: rgba(255, 77, 77, 0.3); }
            100% { background-color: rgba(255, 77, 77, 0); }
        }

        .menu-screen {
            position: absolute;
            inset: 0;
            background: rgba(0,0,0,0.85);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            z-index: 100;
        }

        .loading-spinner {
            border: 4px solid rgba(255, 255, 255, 0.1);
            border-left-color: var(--dojo-gold);
            border-radius: 50%;
            width: 40px;
            height: 40px;
            animation: spin 1s linear infinite;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        button {
            transition: all 0.2s ease;
        }

        button:hover {
            transform: scale(1.05);
            box-shadow: 0 0 20px rgba(255, 215, 0, 0.4);
        }
    </style>
</head>
<body>

    <div id="game-container">
        <video id="input-video" playsinline></video>
        <canvas id="output-canvas"></canvas>

        <div class="ui-overlay">
            <div class="status-bar">
                <div class="flex flex-col gap-2">
                    <div class="title-font text-3xl text-yellow-400 tracking-wider">SHADOW DOJO</div>
                    <div class="flex items-center gap-4">
                        <div class="health-bar-container">
                            <div id="health-fill"></div>
                        </div>
                        <span id="score-display" class="text-2xl font-bold">SCORE: 0</span>
                    </div>
                </div>
                <div class="flex flex-col items-end">
                    <div id="mode-display" class="text-xl font-bold text-blue-400">LOADING CAMERA...</div>
                    <div id="fps-counter" class="text-xs text-gray-500">FPS: --</div>
                </div>
            </div>
            <div id="damage-overlay" class="absolute inset-0 pointer-events-none"></div>
        </div>

        <!-- Start Screen -->
        <div id="menu-screen" class="menu-screen">
            <h1 class="title-font text-7xl mb-2 text-yellow-500 text-center">KINETIC MASTER</h1>
            <p class="text-gray-400 mb-8 max-w-md text-center">Inspired by the "Way of the Warrior", but powered by AI. Use your body to strike targets and avoid obstacles.</p>
            
            <div id="loading-area" class="flex flex-col items-center gap-4">
                <div class="loading-spinner"></div>
                <p id="loading-text">Initializing Pose Tracking...</p>
            </div>

            <div id="start-controls" class="hidden flex flex-col gap-4 w-full max-w-xs interactive">
                <button onclick="startGame('strike')" class="bg-red-600 hover:bg-red-500 text-white font-bold py-4 px-8 rounded-full text-xl shadow-lg uppercase tracking-widest border-b-4 border-red-800">
                    Spirit Strike Mode
                </button>
                <button onclick="startGame('reflex')" class="bg-blue-600 hover:bg-blue-500 text-white font-bold py-4 px-8 rounded-full text-xl shadow-lg uppercase tracking-widest border-b-4 border-blue-800">
                    Guardian Reflex Mode
                </button>
                <p class="text-xs text-gray-500 text-center mt-4">Stand back so your whole body is visible.</p>
            </div>
        </div>

        <!-- Game Over Screen -->
        <div id="game-over-screen" class="menu-screen hidden">
            <h1 class="title-font text-6xl mb-2 text-red-500">DEFEATED</h1>
            <p id="final-score" class="text-2xl mb-4">FINAL SCORE: 0</p>
            
            <div id="leaderboard" class="w-full max-w-sm glass-panel p-4 mb-6 hidden">
                <h2 class="title-font text-xl text-yellow-400 mb-3 text-center">HALL OF FAME</h2>
                <div id="score-list" class="space-y-1 text-sm">
                    <!-- Scores injected here -->
                </div>
            </div>

            <div class="flex flex-col gap-3 interactive">
                <input type="text" id="player-name" placeholder="Enter Ninja Name" maxlength="15" 
                       class="bg-gray-800 border border-gray-600 rounded p-2 text-center text-white focus:outline-none focus:border-yellow-500">
                <button id="submit-score-btn" onclick="submitScoreToFirebase()" class="bg-green-600 hover:bg-green-500 text-white font-bold py-3 px-6 rounded-full text-lg shadow-lg">
                    SUBMIT TO LEADERBOARD
                </button>
                <button onclick="location.reload()" class="bg-gray-700 hover:bg-gray-600 text-white font-bold py-3 px-6 rounded-full text-lg shadow-lg">
                    RETRY
                </button>
            </div>
        </div>
    </div>

    <!-- Firebase SDKs -->
    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-app.js";
        import { getAuth, signInAnonymously, onAuthStateChanged } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-auth.js";
        import { getFirestore, collection, addDoc, query, orderBy, limit, getDocs, serverTimestamp } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-firestore.js";

      const firebaseConfig = {
    apiKey: "AIzaSyDaQDHVELYHyCIgRntocA7HUS7V0XLt980",
    authDomain: "dojo-236be.firebaseapp.com",
    projectId: "dojo-236be",
    storageBucket: "dojo-236be.firebasestorage.app",
    messagingSenderId: "828828279034",
    appId: "1:828828279034:web:2abbdaf35d5287dea72943"
  };

        // Initialize Firebase
        const app = initializeApp(firebaseConfig);
        const auth = getAuth(app);
        const db = getFirestore(app);
        let currentUserId = null;

        // Sign in anonymously
        signInAnonymously(auth).catch(err => console.error("Firebase Auth Error:", err));
        onAuthStateChanged(auth, (user) => { if (user) currentUserId = user.uid; });

        // Exposure of functions to window for onclick handlers
        window.submitScoreToFirebase = async () => {
            const nameInput = document.getElementById('player-name');
            const btn = document.getElementById('submit-score-btn');
            const name = nameInput.value.trim() || "Anonymous Ninja";

            btn.disabled = true;
            btn.innerText = "SAVING...";

            try {
                await addDoc(collection(db, "high_scores"), {
                    name: name,
                    score: gameState.score,
                    mode: gameState.gameMode,
                    timestamp: serverTimestamp()
                });
                btn.innerText = "SCORE SAVED!";
                fetchLeaderboard();
            } catch (error) {
                console.error("Error saving score:", error);
                btn.innerText = "SAVE FAILED";
                btn.disabled = false;
            }
        };

        window.fetchLeaderboard = async () => {
            const scoreList = document.getElementById('score-list');
            const boardContainer = document.getElementById('leaderboard');
            scoreList.innerHTML = "<p class='text-center opacity-50'>Fetching Scroll of Honor...</p>";
            boardContainer.classList.remove('hidden');

            try {
                const q = query(collection(db, "high_scores"), orderBy("score", "desc"), limit(10));
                const querySnapshot = await getDocs(q);
                
                scoreList.innerHTML = "";
                let rank = 1;
                querySnapshot.forEach((doc) => {
                    const data = doc.data();
                    const item = document.createElement('div');
                    item.className = "flex justify-between border-b border-white/5 py-1";
                    item.innerHTML = `<span>${rank}. ${data.name}</span><span class='text-yellow-400 font-bold'>${data.score}</span>`;
                    scoreList.appendChild(item);
                    rank++;
                });

                if (querySnapshot.empty) scoreList.innerHTML = "No legends yet...";
            } catch (error) {
                console.error("Error fetching leaderboard:", error);
                scoreList.innerHTML = "Leaderboard connection lost.";
            }
        };
    </script>

    <script>
        /**
         * GAME ENGINE - PRESERVED LOGIC
         */
        const videoElement = document.getElementById('input-video');
        const canvasElement = document.getElementById('output-canvas');
        const canvasContext = canvasElement.getContext('2d');
        const healthFill = document.getElementById('health-fill');
        const scoreDisplay = document.getElementById('score-display');
        const menuScreen = document.getElementById('menu-screen');
        const gameOverScreen = document.getElementById('game-over-screen');
        const damageOverlay = document.getElementById('damage-overlay');

        let gameState = {
            isRunning: false,
            score: 0,
            health: 100,
            gameMode: 'strike',
            targets: [],
            particles: [],
            lastFrameTime: 0,
            difficulty: 1.0,
            poseLandmarks: null
        };

        const COLORS = { ENEMY: '#ff4d4d', FRIEND: '#00d4ff', PLAYER: '#ffd700' };

        class GameTarget {
            constructor(mode) {
                this.radius = 40 + (Math.random() * 20);
                this.isFriendly = (mode === 'reflex' && Math.random() > 0.7);
                const side = Math.floor(Math.random() * 4);
                if (side === 0) { this.x = Math.random() * canvasElement.width; this.y = -this.radius; }
                else if (side === 1) { this.x = canvasElement.width + this.radius; this.y = Math.random() * canvasElement.height; }
                else if (side === 2) { this.x = Math.random() * canvasElement.width; this.y = canvasElement.height + this.radius; }
                else { this.x = -this.radius; this.y = Math.random() * canvasElement.height; }
                const centerX = canvasElement.width / 2, centerY = canvasElement.height / 2;
                const angle = Math.atan2(centerY - this.y, centerX - this.x);
                const speed = (2 + Math.random() * 3) * gameState.difficulty;
                this.velocityX = Math.cos(angle) * speed;
                this.velocityY = Math.sin(angle) * speed;
                this.pulsate = 0; this.isHit = false;
            }
            update() {
                this.x += this.velocityX; this.y += this.velocityY; this.pulsate += 0.1;
                const dx = this.x - (canvasElement.width / 2), dy = this.y - (canvasElement.height / 2);
                const distanceToCenter = Math.sqrt(dx * dx + dy * dy);
                if (distanceToCenter < 100 && !this.isHit) {
                    if (!this.isFriendly) applyDamage(15);
                    this.isHit = true; return true;
                }
                if (gameState.poseLandmarks) {
                    const strikePoints = [15, 16, 19, 20, 31, 32];
                    for (let index of strikePoints) {
                        const landmark = gameState.poseLandmarks[index];
                        const mirroredX = 1 - landmark.x; 
                        const px = mirroredX * canvasElement.width, py = landmark.y * canvasElement.height;
                        if (Math.sqrt(Math.pow(this.x - px, 2) + Math.pow(this.y - py, 2)) < this.radius + 25) {
                            this.handleStrike(); return true;
                        }
                    }
                }
                return false;
            }
            handleStrike() {
                this.isHit = true;
                if (this.isFriendly) { applyDamage(20); spawnExplosion(this.x, this.y, COLORS.FRIEND); }
                else { gameState.score += 10; scoreDisplay.innerText = `SCORE: ${gameState.score}`; spawnExplosion(this.x, this.y, COLORS.ENEMY); gameState.difficulty += 0.01; }
            }
            draw(ctx) {
                ctx.save(); ctx.shadowBlur = 10 + Math.sin(this.pulsate)*5;
                ctx.shadowColor = this.isFriendly ? COLORS.FRIEND : COLORS.ENEMY;
                ctx.fillStyle = this.isFriendly ? COLORS.FRIEND : COLORS.ENEMY;
                ctx.beginPath(); ctx.arc(this.x, this.y, this.radius, 0, Math.PI * 2); ctx.fill();
                ctx.strokeStyle = 'white'; ctx.lineWidth = 2; ctx.beginPath(); ctx.arc(this.x, this.y, this.radius * 0.7, 0, Math.PI * 2); ctx.stroke();
                ctx.restore();
            }
        }

        function spawnExplosion(x, y, color) {
            for (let i = 0; i < 15; i++) gameState.particles.push({ x, y, vx: (Math.random() - 0.5) * 10, vy: (Math.random() - 0.5) * 10, life: 1.0, color });
        }

        function applyDamage(amount) {
            gameState.health -= amount; healthFill.style.width = `${Math.max(0, gameState.health)}%`;
            damageOverlay.classList.add('flash-red'); setTimeout(() => damageOverlay.classList.remove('flash-red'), 300);
            if (gameState.health <= 0) endGame();
        }

        function startGame(mode) {
            gameState.isRunning = true; gameState.score = 0; gameState.health = 100; gameState.gameMode = mode;
            gameState.targets = []; gameState.particles = []; gameState.difficulty = 1.0;
            scoreDisplay.innerText = `SCORE: 0`; healthFill.style.width = `100%`;
            document.getElementById('mode-display').innerText = mode.toUpperCase() + " MODE";
            menuScreen.classList.add('hidden'); gameOverScreen.classList.add('hidden');
        }

        function endGame() {
            gameState.isRunning = false;
            document.getElementById('final-score').innerText = `FINAL SCORE: ${gameState.score}`;
            gameOverScreen.classList.remove('hidden');
            // Fetch leaderboard after game ends
            if (typeof fetchLeaderboard === "function") fetchLeaderboard();
        }

        const pose = new Pose({ locateFile: (file) => `https://cdn.jsdelivr.net/npm/@mediapipe/pose/${file}` });
        pose.setOptions({ modelComplexity: 1, smoothLandmarks: true, minDetectionConfidence: 0.5, minTrackingConfidence: 0.5 });
        pose.onResults((results) => {
            if (canvasElement.width !== window.innerWidth) { canvasElement.width = window.innerWidth; canvasElement.height = window.innerHeight; }
            gameState.poseLandmarks = results.poseLandmarks;
            canvasContext.save(); canvasContext.clearRect(0, 0, canvasElement.width, canvasElement.height);
            canvasContext.translate(canvasElement.width, 0); canvasContext.scale(-1, 1);
            canvasContext.drawImage(results.image, 0, 0, canvasElement.width, canvasElement.height);
            if (results.poseLandmarks) {
                drawConnectors(canvasContext, results.poseLandmarks, POSE_CONNECTIONS, { color: '#ffffff', lineWidth: 2 });
                drawLandmarks(canvasContext, results.poseLandmarks, { color: COLORS.PLAYER, radius: 4 });
            }
            canvasContext.restore();
            if (gameState.isRunning) {
                if (Math.random() < 0.02 * gameState.difficulty) gameState.targets.push(new GameTarget(gameState.gameMode));
                for (let i = gameState.targets.length - 1; i >= 0; i--) if (gameState.targets[i].update()) gameState.targets.splice(i, 1); else gameState.targets[i].draw(canvasContext);
                for (let i = gameState.particles.length - 1; i >= 0; i--) {
                    const p = gameState.particles[i]; p.x += p.vx; p.y += p.vy; p.life -= 0.02;
                    if (p.life <= 0) gameState.particles.splice(i, 1);
                    else { canvasContext.globalAlpha = p.life; canvasContext.fillStyle = p.color; canvasContext.beginPath(); canvasContext.arc(p.x, p.y, 3, 0, Math.PI * 2); canvasContext.fill(); }
                }
                canvasContext.globalAlpha = 1.0;
                canvasContext.strokeStyle = 'rgba(255, 255, 255, 0.2)'; canvasContext.setLineDash([5, 5]); canvasContext.beginPath(); canvasContext.arc(canvasElement.width/2, canvasElement.height/2, 80, 0, Math.PI * 2); canvasContext.stroke(); canvasContext.setLineDash([]);
            }
            const now = performance.now(); document.getElementById('fps-counter').innerText = `FPS: ${Math.round(1000 / (now - gameState.lastFrameTime))}`; gameState.lastFrameTime = now;
        });

        const camera = new Camera(videoElement, { onFrame: async () => { await pose.send({ image: videoElement }); }, width: 1280, height: 720 });
        camera.start().then(() => { document.getElementById('loading-area').classList.add('hidden'); document.getElementById('start-controls').classList.remove('hidden'); document.getElementById('mode-display').innerText = "DOJO READY"; });
        window.addEventListener('resize', () => { canvasElement.width = window.innerWidth; canvasElement.height = window.innerHeight; });
    </script>
</body>
</html>
</body>
</html>
